{
	"name": "pl_project_submission",
	"properties": {
		"activities": [
			{
				"name": "ForEach",
				"type": "ForEach",
				"dependsOn": [],
				"userProperties": [],
				"typeProperties": {
					"items": {
						"value": "@pipeline().parameters.csvList",
						"type": "Expression"
					},
					"isSequential": true,
					"activities": [
						{
							"name": "Copy MARA VBRK VBAP",
							"type": "Copy",
							"dependsOn": [],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"source": {
									"type": "DelimitedTextSource",
									"storeSettings": {
										"type": "AzureBlobFSReadSettings",
										"recursive": true,
										"enablePartitionDiscovery": false
									},
									"formatSettings": {
										"type": "DelimitedTextReadSettings"
									}
								},
								"sink": {
									"type": "DelimitedTextSink",
									"storeSettings": {
										"type": "AzureBlobFSWriteSettings"
									},
									"formatSettings": {
										"type": "DelimitedTextWriteSettings",
										"quoteAllText": true,
										"fileExtension": ".txt"
									}
								},
								"enableStaging": false,
								"translator": {
									"type": "TabularTranslator",
									"typeConversion": true,
									"typeConversionSettings": {
										"allowDataTruncation": true,
										"treatBooleanAsNumber": false
									}
								}
							},
							"inputs": [
								{
									"referenceName": "ds_source_copy_3CSV",
									"type": "DatasetReference",
									"parameters": {
										"fileName": {
											"value": "@item().fileName",
											"type": "Expression"
										}
									}
								}
							],
							"outputs": [
								{
									"referenceName": "ds_target_copy_3CSV",
									"type": "DatasetReference",
									"parameters": {
										"FileName": {
											"value": "@item().fileName",
											"type": "Expression"
										}
									}
								}
							]
						},
						{
							"name": "Get Metadata for copied files",
							"type": "GetMetadata",
							"dependsOn": [
								{
									"activity": "Copy MARA VBRK VBAP",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"dataset": {
									"referenceName": "ds_getMetaData",
									"type": "DatasetReference",
									"parameters": {
										"FileName": {
											"value": "@item().fileName",
											"type": "Expression"
										}
									}
								},
								"fieldList": [
									"itemName",
									"size"
								],
								"storeSettings": {
									"type": "AzureBlobFSReadSettings",
									"recursive": true,
									"enablePartitionDiscovery": false
								},
								"formatSettings": {
									"type": "DelimitedTextReadSettings"
								}
							}
						},
						{
							"name": "If Condition",
							"type": "IfCondition",
							"dependsOn": [
								{
									"activity": "Get Metadata for copied files",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"userProperties": [],
							"typeProperties": {
								"expression": {
									"value": "@greaterOrEquals(activity('Get Metadata for copied files').output.size, variables('MaxFileSize'))\n\n\n",
									"type": "Expression"
								},
								"ifTrueActivities": [
									{
										"name": "Set variable -maxFileName",
										"type": "SetVariable",
										"dependsOn": [],
										"policy": {
											"secureOutput": false,
											"secureInput": false
										},
										"userProperties": [],
										"typeProperties": {
											"variableName": "MaxFileName",
											"value": {
												"value": "@activity('Get Metadata for copied files').output.itemName",
												"type": "Expression"
											}
										}
									},
									{
										"name": "Set variable maxFileSize",
										"type": "SetVariable",
										"dependsOn": [
											{
												"activity": "Set variable -maxFileName",
												"dependencyConditions": [
													"Succeeded"
												]
											}
										],
										"policy": {
											"secureOutput": false,
											"secureInput": false
										},
										"userProperties": [],
										"typeProperties": {
											"variableName": "MaxFileSize",
											"value": {
												"value": "@activity('Get Metadata for copied files').output.size\n",
												"type": "Expression"
											}
										}
									}
								]
							}
						}
					]
				}
			},
			{
				"name": "Copy largest from Silver",
				"type": "Copy",
				"dependsOn": [
					{
						"activity": "ForEach",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "DelimitedTextSource",
						"storeSettings": {
							"type": "AzureBlobFSReadSettings",
							"recursive": true,
							"enablePartitionDiscovery": false
						},
						"formatSettings": {
							"type": "DelimitedTextReadSettings"
						}
					},
					"sink": {
						"type": "DelimitedTextSink",
						"storeSettings": {
							"type": "AzureBlobFSWriteSettings"
						},
						"formatSettings": {
							"type": "DelimitedTextWriteSettings",
							"quoteAllText": true,
							"fileExtension": ".txt"
						}
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{
						"referenceName": "ds_source_copy_largestfile",
						"type": "DatasetReference",
						"parameters": {
							"FileName": {
								"value": "@variables('MaxFileName')",
								"type": "Expression"
							}
						}
					}
				],
				"outputs": [
					{
						"referenceName": "ds_target_largestfile",
						"type": "DatasetReference"
					}
				]
			},
			{
				"name": "ForEach for Loading SQL Tables",
				"type": "ForEach",
				"dependsOn": [],
				"userProperties": [],
				"typeProperties": {
					"items": {
						"value": "@pipeline().parameters.tableList",
						"type": "Expression"
					},
					"isSequential": true,
					"activities": [
						{
							"name": "Copy_last12days_source_targetSQL",
							"type": "Copy",
							"dependsOn": [],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"source": {
									"type": "AzureSqlSource",
									"sqlReaderQuery": {
										"value": "Select * \nfrom bronze.@{item().TableName}\nwhere @{item().WaterMark_Column} >= \n'@{formatDateTime(adddays(utcNow(),-12), 'yyyy-MM-dd')}'",
										"type": "Expression"
									},
									"queryTimeout": "02:00:00",
									"partitionOption": "None"
								},
								"sink": {
									"type": "AzureSqlSink",
									"preCopyScript": {
										"value": "Delete\nfrom silver.@{item().TableName}\nwhere @{item().WaterMark_Column} >= '@{formatDateTime(adddays(utcNow(),-12), 'yyyy-MM-dd')}'",
										"type": "Expression"
									},
									"writeBehavior": "insert",
									"sqlWriterUseTableLock": false,
									"disableMetricsCollection": false
								},
								"enableStaging": false,
								"translator": {
									"type": "TabularTranslator",
									"typeConversion": true,
									"typeConversionSettings": {
										"allowDataTruncation": true,
										"treatBooleanAsNumber": false
									}
								}
							},
							"inputs": [
								{
									"referenceName": "ds_full_load_last_12_dys",
									"type": "DatasetReference",
									"parameters": {
										"SchemaName": "bronze",
										"TableName": {
											"value": "@item().TableName",
											"type": "Expression"
										}
									}
								}
							],
							"outputs": [
								{
									"referenceName": "ds_target_full_load_last_12_days",
									"type": "DatasetReference",
									"parameters": {
										"SchemaName": "silver",
										"TableName": {
											"value": "@item().TableName",
											"type": "Expression"
										}
									}
								}
							]
						}
					]
				}
			},
			{
				"name": "Set variable LatestTable",
				"type": "SetVariable",
				"dependsOn": [
					{
						"activity": "Lookup for fetching latest table",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"variableName": "LatestUpdatedTableName",
					"value": {
						"value": "@activity('Lookup for fetching latest table').output.firstRow.TableName",
						"type": "Expression"
					}
				}
			},
			{
				"name": "Set variable Latest Table Timestamp",
				"type": "SetVariable",
				"dependsOn": [
					{
						"activity": "Set variable LatestTable",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"variableName": "LastUpdatedTimestamp",
					"value": {
						"value": "@activity('Lookup for fetching latest table').output.firstRow.MaxUpdate",
						"type": "Expression"
					}
				}
			},
			{
				"name": "Lookup for fetching latest table",
				"type": "Lookup",
				"dependsOn": [
					{
						"activity": "ForEach for Loading SQL Tables",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "AzureSqlSource",
						"sqlReaderQuery": "SELECT  TOP 1 TableName,MaxUpdate\nFROM (\n    SELECT 'COSTLIST' AS TableName, MAX(LASTUPDATED_LastModified) AS MaxUpdate FROM silver.COSTLIST\n    UNION ALL\n    SELECT 'INVOICELINEITEM' AS TableName, MAX(LASTUPDATED_LastModified) AS MaxUpdate FROM silver.INVOICE_LINE_ITEM\n    UNION ALL\n    SELECT 'PRODUCINGSTTS' AS TableName, MAX(LASTUPDATED_LastModified) AS MaxUpdate FROM silver.PRODUCING_STAT_RATIO_DETAIL\n) AS Combined\nORDER BY MaxUpdate DESC;",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"dataset": {
						"referenceName": "lookup_target_latesttable",
						"type": "DatasetReference"
					}
				}
			},
			{
				"name": "Copy latest table from target sql to gold adls",
				"type": "Copy",
				"dependsOn": [
					{
						"activity": "Set variable Latest Table Timestamp",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "AzureSqlSource",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"sink": {
						"type": "DelimitedTextSink",
						"storeSettings": {
							"type": "AzureBlobFSWriteSettings"
						},
						"formatSettings": {
							"type": "DelimitedTextWriteSettings",
							"quoteAllText": true,
							"fileExtension": ".txt"
						}
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{
						"referenceName": "ds_source_copy_latest_gold_adls",
						"type": "DatasetReference",
						"parameters": {
							"SchemaName": "silver",
							"TableName": {
								"value": "@variables('LatestUpdatedTableName')",
								"type": "Expression"
							}
						}
					}
				],
				"outputs": [
					{
						"referenceName": "ds_source_target_gold",
						"type": "DatasetReference",
						"parameters": {
							"TableName": {
								"value": "@variables('LatestUpdatedTableName')",
								"type": "Expression"
							}
						}
					}
				]
			}
		],
		"parameters": {
			"csvList": {
				"type": "array",
				"defaultValue": [
					{
						"fileName": "MARA.csv"
					},
					{
						"fileName": "VBAP.csv"
					},
					{
						"fileName": "VBRK.csv"
					}
				]
			},
			"tableList": {
				"type": "array",
				"defaultValue": [
					{
						"TableName": "COSTLIST",
						"WaterMark_Column": "LASTUPDATED_LastModified"
					},
					{
						"TableName": "INVOICE_LINE_ITEM",
						"WaterMark_Column": "LASTUPDATED_LastModified"
					},
					{
						"TableName": "PRODUCING_STAT_RATIO_DETAIL",
						"WaterMark_Column": "LASTUPDATED_LastModified"
					}
				]
			}
		},
		"variables": {
			"MaxFileName": {
				"type": "String",
				"defaultValue": "''"
			},
			"MaxFileSize": {
				"type": "Integer",
				"defaultValue": 0
			},
			"LatestUpdatedTableName": {
				"type": "String"
			},
			"LastUpdatedTimestamp": {
				"type": "String"
			}
		},
		"annotations": []
	}
}